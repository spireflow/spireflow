{
  "name": "nellavio",
  "version": "2.0.0",
  "license": "MIT",
  "description": "Open source dashboard starter built with Next.js 16, TypeScript and Tailwind 4",
  "author": {
    "name": "matt765",
    "email": "mateusz.wyrebek@gmail.com",
    "url": "https://matt765.dev/"
  },
  "private": false,
  "scripts": {
    "predev": "tsx src/utils/banner.ts",
    "dev": "next dev",
    "build": "next build",
    "prestart": "tsx src/utils/banner.ts",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
